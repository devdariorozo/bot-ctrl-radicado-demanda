# ===================================================
# Variables de entorno para el proyecto
# ==================================================

# App
PROJECT_NAME=my_project_name
VERSION_API=my_version_api
ENV_API=my_env_api
PORT_API=my_port_api
URL_API=my_url_api

# BD Configuración (mysql | postgres)
SCHEMA=my_schema
DB_CONFIG_HOST=my_db_config_host
DB_CONFIG_PORT=my_db_config_port
DB_CONFIG_USER=my_db_config_user
DB_CONFIG_PASSWORD=my_db_config_password
DB_CONFIG_DATABASE=my_db_config_database
DB_CONFIG_LOGGING=my_db_config_logging

# Redis (opcional - colas BullMQ; con network_mode: host usar localhost de lo contrario redis)
REDIS_HOST=my_redis_host
REDIS_PORT=my_redis_port

# Bot control / Automation loop (segundos)
# Espera cuando no hay demanda procesada (cola vacía).
AUTOMATION_IDLE_SLEEP_SEC=my_automation_idle_sleep_sec
# Espera entre demandas cuando sí se procesó una (gestión continua).
AUTOMATION_BETWEEN_DEMANDS_SEC=my_automation_between_demands_sec
# Espera en standby (horario/festivo o error de portal).
AUTOMATION_STANDBY_SLEEP_SEC=my_automation_standby_sleep_sec
# Espera cuando el bot está detenido antes de volver a consultar.
AUTOMATION_BOT_STOPPED_SLEEP_SEC=my_automation_bot_stopped_sleep_sec

# Job: consulta y registro demandas Sin presentar, Presentada y Presentada por aplicativo (sync)
# Intervalo (en minutos) para que el bot consulte.
DEMANDS_PRESENTED_SYNC_INTERVAL_MINUTES=my_demands_presented_sync_interval_minutes
# Tipo de ejecucion: (true: manual, false: automatico)
DEMANDS_PRESENTED_SYNC_MANUAL=my_demands_presented_sync_manual
# Datos especiificos de la ejecucion manual
LAWSUIT_ID=my_lawsuit_id
CLIENT_ID=my_client_id

# Servicio de correo para automatización (IMAP o POP3)
MAIL_HOST=my_mail_host
MAIL_PROTOCOL=my_mail_protocol
MAIL_PORT=my_mail_port
MAIL_USER=my_mail_user
MAIL_PASSWORD=my_mail_password
MAIL_FOLDER=my_mail_folder
# Palabras clave en el asunto del correo para sincronizar separadas por comas
MAIL_SUBJECT_KEYWORDS=my_mail_subject_keywords
# Substrings de nombres de archivos PDF adjuntos a procesar (Municipal.pdf,ActaReparto) separados por comas.
MAIL_PDF_ATTACHMENT_PATTERNS=my_mail_pdf_attachment_patterns
# Job: automatizacion correo (sync)
# Intervalo (en minutos) para que el bot consulte los correos.
AUTOMATION_EMAIL_SYNC_INTERVAL_MINUTES=my_automation_email_sync_interval_minutes
# Tiempo máximo (ms) de espera por respuesta POP3 antes de abortar el ciclo (default: 10 minutos).
MAIL_POP3_TIMEOUT_MS=my_mail_pop3_timeout_ms
# Limit de correos a procesar por ciclo vía UIDL (100 correos).
MAIL_POP3_BATCH_SIZE=my_mail_pop3_batch_size

# Servicio portal de consultas
PORTAL_QUERIES_URL=my_portal_queries_url
PUPPETEER_SHOW_BROWSER=my_puppeteer_show_browser
# Minutos de espera antes de reintentar un registro en estado 'Novedad portal' (portal caído).
PORTAL_RETRY_INTERVAL_MINUTES=my_portal_retry_interval_minutes
# Segundos de espera antes de reintentar una consulta en el portal.
PORTAL_QUERY_WAIT_TIME=my_portal_query_wait_time

# Company names portfolios
# Carteras propias ej: 1:CONTACTO SOLUTIONS,2:NOVARTEC (Separadas por comas)
COMPANY_NAMES_PORTFOLIO_PROPIAS=my_company_names_portfolio_propias

# Job: purga diaria de registros de correo automatizado vencidos
# Formato: DD
AUTOMATION_EMAIL_EXPIRATION_DAYS=my_automation_email_expiration_days
# Formato: HH:MM 24 horas
AUTOMATION_EMAIL_EXPIRATION_HOURS=my_automation_email_expiration_hours

# LOGS: archivo diario (YYYY-MM-DD-logs-{LOG_SYSTEM_NAME}.log) y retención
LOG_RETENTION_DAYS=my_log_retention_days
