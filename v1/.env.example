# ===================================================
# Variables de entorno para el entorno de desarrollo
# ==================================================

# App
PROJECT_NAME=my_project_name
VERSION_API=my_version_api
ENV_API=my_env_api
PORT_API=my_port_api
URL_API=http://localhost:my_port_api

# MySQL - BD Configuración
DB_CONFIG_HOST=my_db_host
DB_CONFIG_PORT=my_db_port
DB_CONFIG_USER=my_db_user
DB_CONFIG_PASSWORD=my_db_password
DB_CONFIG_DATABASE=my_db_database
DB_CONFIG_LOGGING=my_db_logging

# Redis (opcional - colas BullMQ; con network_mode: host usar localhost de lo contrario redis)
REDIS_HOST=my_redis_host
REDIS_PORT=my_redis_port

# CORS: lista de origins separados por comas. Usar * para paso abierto (sin restricciones).
CORS_ALLOWED_ORIGINS=my_cors_allowed_origins

# Bot control / Automation loop (segundos)
# Espera cuando no hay demanda procesada (cola vacía).
AUTOMATION_IDLE_SLEEP_SEC=my_automation_idle_sleep_sec
# Espera entre demandas cuando sí se procesó una (gestión continua).
AUTOMATION_BETWEEN_DEMANDS_SEC=my_automation_between_demands_sec
# Espera en standby (horario/festivo o error de portal).
AUTOMATION_STANDBY_SLEEP_SEC=my_automation_standby_sleep_sec
# Espera cuando el bot está detenido antes de volver a consultar.
AUTOMATION_BOT_STOPPED_SLEEP_SEC=my_automation_bot_stopped_sleep_sec

# Job: consulta y registro demandas pendientes (sync)
# Intervalo (en minutos) para que el bot consulte demandas pendientes.
DEMANDS_PENDING_SYNC_INTERVAL_MINUTES=my_demands_pending_sync_interval_minutes
# Tipo de ejecucion: (true: manual, false: automatico)
DEMANDS_PENDING_SYNC_MANUAL=my_demands_pending_sync_manual

# Job: consulta y registro demandas Presentada y Presentada por aplicativo (sync)
# Intervalo (en minutos) para que el bot consulte.
DEMANDS_PRESENTED_SYNC_INTERVAL_MINUTES=my_demands_presented_sync_interval_minutes
# Tipo de ejecucion: (true: manual, false: automatico)
DEMANDS_PRESENTED_SYNC_MANUAL=my_demands_presented_sync_manual
# Datos especiificos de la ejecucion manual
LAWSUIT_ID=my_lawsuit_id
CLIENT_ID=my_client_id

# Registro simulado portal demandas en linea (true: simula el registro, false: registra real)
DEMANDS_PENDING_SYNC_SIMULATED_PORTAL=my_demands_pending_sync_simulated_portal

# Servicio Browserless /stealth mode
BROWSERLESS_ENDPOINT=my_browserless_endpoint
BROWSERLESS_API_TOKEN=my_browserless_api_token
BROWSERLESS_CONCURRENT_BROWSERS=my_concurrent_browsers
BROWSERLESS_SHOW_BROWSER=my_browserless_show_browser

# Servicio S3 descargar pdf demanda
DOWNLOAD_PDF_DEMAND_SERVICE=my_download_pdf_demand_service
DOWNLOAD_PDF_DEMAND_SERVICE_API_KEY=my_download_pdf_demand_service_api_key

# LOGS: archivo diario (YYYY-MM-DD-logs-{LOG_SYSTEM_NAME}.log) y retención
LOG_RETENTION_DAYS=my_log_retention_days

# Servicio de correo POP3 para automatización de bandeja de entrada
MAIL_HOST=my_mail_host
MAIL_PROTOCOL=my_MAIL_PROTOCOL
MAIL_PORT=my_mail_port
MAIL_USER=my_mail_user
MAIL_PASSWORD='my_mail_password'
MAIL_FOLDER=my_mail_folder
